{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "To Do Vrontinos",
  "version": "1.0.2",
  "identifier": "com.vrontinos.todo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "To Do Vrontinos",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1M0VFRjQ0RTE0NUM4RDMKUldUVHlFWGhSTzgrRmFySGNvQkVVaGVqNklHTEt2VUYzanV2WjFmNTJZajBlUmdpSnpBVENqNksK",
      "endpoints": [
    "https://vrontinos-todo-app.vercel.app/updates/latest.json"
],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}